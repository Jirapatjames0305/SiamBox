{
  "name": "siambox",
  "version": "0.0.0",
  "private": true,
  "description": "Thailand → China Cross-Border Ecommerce System",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @siambox/database generate",
    "db:migrate": "pnpm --filter @siambox/database migrate",
    "db:studio": "pnpm --filter @siambox/database studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
