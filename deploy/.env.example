# Copy to deploy/.env on the EC2 instance and fill in. Do NOT commit the real .env.
# Mirrors the keys the API reads (see apps/api/.env.example) plus Caddy's TLS settings.

# ---- Caddy / TLS ----
# Public hostname for the FRONTEND. Must resolve (A record, DNS-only) to this instance's EIP.
WEB_DOMAIN=www.siambox.example
# Public hostname for the API (used when you migrate the API onto this box later).
API_DOMAIN=api.siambox.example
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=you@example.com

# ---- Frontend build/runtime ----
# Baked into the client bundle AND read server-side for SSR. Point at your LIVE API:
#   - during migration: the current Render API URL
#   - after the API moves here: https://api.<your-domain>
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# ---- API runtime ----
NODE_ENV=production
API_PORT=4000
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres?sslmode=require
ADMIN_TOKEN=
# Comma-separated production web origins, e.g. https://siambox.com,https://admin.siambox.com
CORS_ORIGIN=
CNY_TO_THB_RATE=5.0

# ---- Supabase Storage ----
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=siambox-products

# ---- Beam Checkout (production) ----
# Auth is HTTP Basic base64(BEAM_MERCHANT_ID:BEAM_API_KEY).
BEAM_MERCHANT_ID=
BEAM_API_KEY=
BEAM_API_BASE=https://api.beamcheckout.com
# Public web URL Beam redirects customers back to after payment.
WEB_BASE_URL=

# ---- LINE Messaging API (optional) ----
# Push new-order notifications to a LINE group chat.
# Channel access token from LINE Developers Console → Messaging API channel.
# Group ID from the webhook join/message event (groupId field) after adding the bot.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_GROUP_ID=
