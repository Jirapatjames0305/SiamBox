# apps/web — copy to .env.local for local dev
# In production, set these in the Cloudflare Pages project → Settings → Environment variables.
# NEXT_PUBLIC_* values are baked into the client bundle at build time.

# Public URL of the API (Render)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Cloudflare Turnstile site key (CAPTCHA on public forms).
# From dash.cloudflare.com → Turnstile → your widget. Leave unset locally to skip CAPTCHA.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
