# apps/api — set these on Render → Environment.
# Locally the API loads `<repo>/.env` first; this file documents the keys
# the API itself reads.

DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres?sslmode=require

# Render injects $PORT (=10000 by default for free web services).
# Keep API_PORT aligned with what render.yaml sets.
API_PORT=4000

# Comma-separated list of allowed origins for browser requests.
# In production: https://<web>.pages.dev,https://<admin>.pages.dev
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Bearer token required by /api/admin routes
ADMIN_TOKEN=replace-with-a-long-random-string

# Supabase Storage — used for product image uploads.
# URL + service_role key from Supabase dashboard → Settings → API.
# Bucket must exist and be public (Storage → New bucket → "Public").
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=siambox-products

# Omise (test or live keys)
OMISE_PUBLIC_KEY=pkey_test_...
OMISE_SECRET_KEY=skey_test_...
# Public URL of the web app (Cloudflare Pages) for payment redirects
OMISE_RETURN_BASE=https://siambox-web.vercel.app

# Fallback FX rate (CNY → THB) when no live rate is available
CNY_TO_THB_RATE=5.0
