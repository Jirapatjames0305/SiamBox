# apps/api — set these on Render → Environment.
# Locally the API loads `<repo>/.env` first; this file documents the keys
# the API itself reads.

DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres?sslmode=require

# Render injects $PORT (=10000 by default for free web services).
# Keep API_PORT aligned with what render.yaml sets.
API_PORT=4000

# Comma-separated list of allowed origins for browser requests.
# In production: https://<web>.pages.dev,https://<admin>.pages.dev
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Bearer token required by /api/admin routes
ADMIN_TOKEN=replace-with-a-long-random-string

# Supabase Storage — used for product image uploads.
# URL + service_role key from Supabase dashboard → Settings → API.
# Bucket must exist and be public (Storage → New bucket → "Public").
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=siambox-products

# Web app base — where Beam redirects the customer back to after payment.
WEB_BASE_URL=http://localhost:3000

# Beam Checkout (sandbox/playground) — Charges API.
# Auth is HTTP Basic base64(BEAM_MERCHANT_ID:BEAM_API_KEY).
# API key + Merchant ID from the Beam dashboard (Lighthouse → Developers).
BEAM_MERCHANT_ID=
BEAM_API_KEY=
# Defaults to playground; production is https://api.beamcheckout.com
BEAM_API_BASE=https://playground.api.beamcheckout.com

# Fallback FX rate (CNY → THB) when no live rate is available
CNY_TO_THB_RATE=5.0

# LINE Messaging API — push order notifications to a LINE group chat.
# 1. Create a Messaging API channel at developers.line.biz
# 2. Add the bot to your LINE group
# 3. Get LINE_GROUP_ID from the webhook join/message event (groupId field)
# Leave unset to disable LINE notifications.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_GROUP_ID=
